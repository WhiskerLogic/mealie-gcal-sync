# ===========================================
#  Mealie <-> Google Calendar Sync
# ===========================================

# --- Mealie ---

# API key for authenticating with Mealie
MEALIE_API_KEY=your_mealie_api_key_here

# Internal URL where Mealie is reachable (for API calls)
MEALIE_URL=http://127.0.0.1:9925

# Public-facing URL used in Google Calendar event links
# (only needed by sync_master.js)
# MEALIE_PUBLIC_URL=https://mealie.example.com

# --- Google Calendar ---

# The Google Calendar ID to sync with
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Path to Google service account credentials JSON file
# Defaults to ./credentials.json if not set
# GOOGLE_CREDENTIALS_PATH=./credentials.json

# --- Timezone ---

# Fallback timezone if calendar timezone can't be fetched
# TZ=Australia/Sydney
